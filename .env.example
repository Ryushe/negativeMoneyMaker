# Kalshi API credentials
# Get from https://kalshi.com/profile/api after logging in
KALSHI_API_KEY_ID=
KALSHI_API_KEY_SECRET=          # full PEM private key contents

# Model confidence gate
MIN_CONFIDENCE=0.70             # skip signal if model < 70% confident

# Entry / exit thresholds
ENTRY_DISCOUNT=0.50             # buy when market_price <= model_prob * this
EXIT_TARGET=0.90                # sell when market_price >= model_prob * this
EXPIRY_EXIT_DAYS=7              # force-exit N days before expiry
MIN_EDGE=0.03                   # minimum fee-adjusted expected value (3 cents per dollar)

# Position sizing (Kelly)
KELLY_FRACTION=0.25             # fraction of full Kelly to bet (0.25 = quarter-Kelly)
MAX_BANKROLL_USD=1000           # total capital Kelly sizes against
MAX_POSITION_USD=50             # hard cap per single trade

# Fees
KALSHI_FEE_RATE=0.07            # Kalshi takes ~7% of winnings

# Circuit breaker
MAX_DAILY_LOSS_USD=15           # halt new entries if day's P&L drops below -$15
MAX_CONSECUTIVE_LOSSES=3        # cool-off after 3 losses in a row
COOLOFF_MINUTES=60              # how long to pause after hitting consecutive loss limit
MAX_OPEN_POSITIONS=10           # max concurrent open trades

# Misc
RISK_FREE_RATE=0.05             # annual risk-free rate for Sharpe
POLL_INTERVAL_SEC=120           # seconds between market scans
